---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, "") },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const { slug } = Astro.params;
const post = Astro.props;
if (!post) {
  console.error(`no post found by slug ${slug}`);
  return Astro.redirect("/404");
}
const { Content } = await render(post);
const postSlug = post.id.replace(/\.(md|mdx)$/, "");

// TODO theme for utterances
---

<BlogPost {...post.data} slug={postSlug} opengraphImage={post.data.opengraphImage}>
    <Content />
    <script is:inline src="https://utteranc.es/client.js"
            repo="dearlordylord/blog"
            issue-term="pathname"
            theme="github-dark"
            crossorigin="anonymous"
            async>
    </script>
</BlogPost>
